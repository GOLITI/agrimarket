# Variables d'environnement pour le déploiement
# COPIER CE FICHIER EN .env ET REMPLIR LES VALEURS

# Django
SECRET_KEY=changez-cette-cle-secrete-en-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com

# JWT
JWT_SIGNING_KEY=votre-cle-jwt-tres-secrete

# Base de données PostgreSQL (Production)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=agrimarket
DB_USER=postgres
DB_PASSWORD=votre-mot-de-passe-securise
DB_HOST=localhost
DB_PORT=5432

# CORS (Frontend URLs autorisées)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://votre-frontend.com

# Email (optionnel)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre-email@gmail.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app

# Sentry (monitoring - optionnel)
SENTRY_DSN=

# AWS S3 (stockage fichiers - optionnel)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=

# Redis (cache - optionnel)
REDIS_URL=redis://localhost:6379/0

# Docker Hub (pour le pipeline CI/CD)
# Créer un Access Token sur https://hub.docker.com/settings/security
DOCKER_HUB_USER=marco225
DOCKER_HUB_TOKEN=votre-access-token-dockerhub
DOCKER_HUB_IMAGE=marco225/agrimarket
